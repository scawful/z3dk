; =============================================================================
; Sprite: {name}
; Generated by z3dk scaffold
; Bank: ${bank}
; =============================================================================

namespace {namespace} {{

; Long entry point (JSL target from sprite dispatch table)
{name}_Long:
{{
  PHB : PHK : PLB
  JSL Sprite_CheckActive : BCC .not_active
    JSR {name}_Main
  .not_active
  PLB
  RTL
}}

; State machine dispatch (called via JSR from Long entry)
{name}_Main:
{{
  LDA.w SprAction, X
  JSL JumpTableLocal
{state_table}
}}

{state_routines}

}} ; namespace {namespace}
