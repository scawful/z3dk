namespace {namespace} {{

; Long entry point (JSL target from sprite dispatch table)
{name}_Long:
{{
  PHB : PHK : PLB
  JSL Sprite_CheckActive : BCC .not_active
    JSR {name}_Main
  .not_active
  PLB
  RTL
}}

; State machine dispatch (called via JSR from Long entry)
{name}_Main:
{{
  ; Check if NPC is active
  LDA.w SprAction, X
  JSL JumpTableLocal
  dw {name}_Init
  dw {name}_Idle
  dw {name}_Dialogue
}}

{name}_Init:
{{
  ; === BEGIN CUSTOM LOGIC ===
  ; TODO: Set up NPC initial state, graphics
  ; === END CUSTOM LOGIC ===

  INC.w SprAction, X  ; advance to Idle
  RTS
}}

